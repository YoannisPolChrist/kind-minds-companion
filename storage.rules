rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTherapist() {
      return isSignedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'therapist';
    }
    
    match /profile_pictures/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isTherapist());
    }

    match /client_notes/{clientId}/{fileName} {
      allow read, write: if isSignedIn() && (request.auth.uid == clientId || isTherapist());
    }

    match /client_resources/{clientId}/{fileName} {
      allow read, write: if isSignedIn() && (request.auth.uid == clientId || isTherapist());
    }

    match /exercises/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isTherapist();
    }

    match /template_covers/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isTherapist();
    }

    match /exercise_media/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isTherapist();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
