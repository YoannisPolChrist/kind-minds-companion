rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    match /profile_pictures/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || 
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'therapist'
      );
    }

    match /client_notes/{clientId}/{fileName} {
      allow read, write: if request.auth != null && (request.auth.uid == clientId || 
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'therapist'
      );
    }

    match /client_resources/{clientId}/{fileName} {
      allow read, write: if request.auth != null && (request.auth.uid == clientId || 
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'therapist'
      );
    }

    match /exercises/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'therapist';
    }

    match /template_covers/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'therapist';
    }

    match /exercise_media/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'therapist';
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
