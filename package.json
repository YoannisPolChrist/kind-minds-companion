  "scripts": {
    "dev": "vite",
    "start": "vite",
    "web": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "test:modules": "tsx --test tests/modules/**/*.test.ts",
    "test:smoke": "playwright test -c tests/playwright.config.ts",
    "test:smoke:headed": "playwright test -c tests/playwright.config.ts --headed",
