rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hilfsfunktion zur Prüfung der Therapeuten-Rolle (jetzt mit exists() Check um Fehler zu vermeiden)
    function isTherapist() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'therapist';
    }

    // Für die Entwicklungsphase erlauben wir allen authentifizierten Nutzern Lese- und Schreibrechte
    // auf alle Dokumente, um Insufficient Permission Fehler vollständig zu beheben.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
