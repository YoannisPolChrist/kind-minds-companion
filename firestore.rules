rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isTherapist() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'therapist';
    }

    // USERS
    match /users/{userId} {
      allow read: if isOwner(userId) || isTherapist();
      allow create: if isOwner(userId) || isTherapist();
      allow update: if isOwner(userId) || isTherapist();
      allow delete: if isTherapist();
    }

    // EXERCISES
    match /exercises/{exerciseId} {
      allow read: if isTherapist() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow create: if isTherapist();
      allow update: if isTherapist() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow delete: if isTherapist();
    }

    // TEMPLATES
    match /exercise_templates/{templateId} {
      allow read, write: if isTherapist();
    }

    // RESOURCES
    match /resources/{resourceId} {
      // Global resources, readable by clients, writable by therapists
      allow read: if isAuthenticated();
      allow write: if isTherapist();
    }

    // CLIENT RESOURCES
    match /client_resources/{resourceId} {
      allow read: if isTherapist() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow create: if isTherapist();
      allow update, delete: if isTherapist();
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, delete: if isTherapist() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // CHECKINS
    match /checkins/{checkinId} {
      // Checkins use "uid" instead of "clientId"
      allow read: if isTherapist() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // CLIENT NOTES
    match /client_notes/{noteId} {
      allow read: if isTherapist() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow create: if isTherapist() || (isAuthenticated() && request.resource.data.clientId == request.auth.uid);
      allow update, delete: if isTherapist() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
    }
    
    // BACKEND NOTIFICATIONS / MAIL
    match /mail/{mailId} {
      // Handled entirely by Firebase Functions using Admin SDK (bypasses rules)
      allow read, write: if false;
    }

    // CUSTOM AUTH EMAILS
    match /mail_requests/{requestId} {
      // Anyone can request an email (like a password reset). Security relies on the backend checking if the user exists.
      allow create: if true;
    }

    // DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
